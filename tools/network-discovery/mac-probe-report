#!/usr/bin/env bash
set -euo pipefail

stamp="$(date '+%Y-%m-%d %H:%M:%S')"
echo "# Mac Network Probe Report"
echo "generated_at: ${stamp}"
echo "hostname: $(hostname 2>/dev/null || true)"
echo "local_hostname: $(scutil --get LocalHostName 2>/dev/null || true)"
echo "computer_name: $(scutil --get ComputerName 2>/dev/null || true)"
echo

echo "## Hardware Ports"
networksetup -listallhardwareports 2>/dev/null || true
echo

echo "## Interfaces"
ifconfig 2>/dev/null | awk '/^[a-zA-Z0-9]+:/{iface=$1; sub(":","",iface)} /ether /{print iface" ether "$2} /inet /{print iface" inet "$2}' || true
echo

echo "## Default Route"
route -n get default 2>/dev/null || true
echo

echo "## DNS"
networksetup -listallnetworkservices 2>/dev/null | sed '1d' | while IFS= read -r svc; do
  [ -z "$svc" ] && continue
  echo "### ${svc}"
  networksetup -getdnsservers "$svc" 2>/dev/null || true
done
echo

echo "## ARP Neighbors"
arp -an 2>/dev/null || true
echo

echo "## Wi-Fi Status"
/System/Library/PrivateFrameworks/Apple80211.framework/Versions/Current/Resources/airport -I 2>/dev/null || true
echo

echo "## Notes"
echo "此報告只讀取本機網路狀態，不會掃描其他主機，也不會修改設定。"
