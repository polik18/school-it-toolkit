# ─────────────────────────────────────────────────────────────
#  local-ai.env — 本地 AI 端點設定 / local LLM endpoint config
#  複製成 local-ai.env 後填入（已被 .gitignore 忽略）
#  Copy to local-ai.env and fill in (gitignored).
# ─────────────────────────────────────────────────────────────

# 本地 LLM 伺服器（OpenAI 相容）端點與金鑰。
# 例如你用 oMLX / Ollama / LM Studio 等架的本地推理服務。
# Local OpenAI-compatible LLM server endpoint & key (e.g. oMLX / Ollama / LM Studio).
LOCAL_LLM_API_BASE="http://YOUR-AI-SERVER:8000/v1"
LOCAL_LLM_API_KEY="your-local-api-key"
LOCAL_LLM_MODEL="openai/your-model-name"

# 要把 aider 安裝給哪個本機帳號使用（通常是學生帳號）。
# Which local account on each Mac should get aider (usually the student account).
TARGET_USER="user"
